# Copy to .env and set after deploy (yarn deploy:contracts | deploy:preview | deploy:preprod)
OBSIDIAN_CONTRACT_ADDRESS=

# Deploy wallet seed (64-char hex). Never commit .env.
# Preview (Lace default): https://faucet.preview.midnight.network/
# Preprod: https://faucet.preprod.midnight.network/
DEPLOY_SEED=

# Optional: local proof server instead of hosted lace-proof-pub.* (see docs.midnight.network/relnotes/network)
# MIDNIGHT_PROOF_SERVER=http://127.0.0.1:6300

# Remote wallet sync wait (ms) before deploy fails with a clear error
# WALLET_SYNC_TIMEOUT_MS=300000

# Matching relayer (yarn relayer)
RELAYER_SEED=

# CLI tools (yarn submit:pair, yarn match-existing)
# CLI_SEED=
# CLI_ASSET=
# CLI_PRICE=

# OBSIDIAN_RELAYER_PRIVATE_STATE_ID=RelayerObsidianState
# OBSIDIAN_RELAYER_HTTP_PORT=3033
# OBSIDIAN_ACTIVITY_LOG=.obsidian/activity.jsonl
# OBSIDIAN_ORDERS_LOG=.obsidian/orders.jsonl
