# Copy to .env and set after `yarn deploy:contracts`
OBSIDIAN_CONTRACT_ADDRESS=

# Deploy (yarn deploy:contracts | yarn deploy:preprod)
# Preprod: fund at https://faucet.preprod.midnight.network/ and register DUST first
DEPLOY_SEED=

# Optional override when proof server is not on localhost:6300
# MIDNIGHT_PROOF_SERVER=http://127.0.0.1:6300

# Preprod wallet sync wait (ms) before deploy gives up with a clear error
# WALLET_SYNC_TIMEOUT_MS=300000

# Matching relayer (yarn relayer)
RELAYER_SEED=

# CLI tools (yarn submit:pair, yarn match-existing)
# CLI_SEED=
# CLI_ASSET=
# CLI_PRICE=

# OBSIDIAN_RELAYER_PRIVATE_STATE_ID=RelayerObsidianState
# OBSIDIAN_RELAYER_HTTP_PORT=3033
# OBSIDIAN_ACTIVITY_LOG=.obsidian/activity.jsonl
# OBSIDIAN_ORDERS_LOG=.obsidian/orders.jsonl
