{
  "name": "obsidian-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Root scripts for frontend (demo UI) + core (Midnight contract & harness).",
  "scripts": {
    "frontend:dev": "npm run dev --prefix frontend",
    "frontend:build": "npm run build --prefix frontend",
    "test": "yarn --cwd core test",
    "test:local": "yarn --cwd core test:local",
    "env:up": "docker compose -f core/compose.yml up -d --wait",
    "env:down": "docker compose -f core/compose.yml down",
    "validate": "yarn env:up && yarn test:local; yarn env:down",
    "relayer": "yarn --cwd core relayer",
    "demo:contracts": "yarn --cwd core demo:contracts",
    "demo:submit-pair": "yarn --cwd core demo:submit-pair",
    "match-existing": "yarn --cwd core match-existing"
  },
  "packageManager": "yarn@1.22.22"
}
